# GitHub backup scope: keep only the Flutter app code and CI workflow.
*
!.gitignore
!.github/
!.github/workflows/
!.github/workflows/flutter-android-build.yml
!flutter_app/
!flutter_app/**
!CHANGELOG.md
desktop_sync_tool/
desktop_sync_tool/**
desktop_sync_tool/.vs/
desktop_sync_tool/**/bin/
desktop_sync_tool/**/obj/

# Local tests only (do not upload)
flutter_app/test/

# Local runtime logs (auto-generated)
flutter_app/flutter_*.log

# Local Android/Kotlin build caches
flutter_app/android/.kotlin/
